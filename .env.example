# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/football_fam

# ── API Keys ─────────────────────────────────────────────
API_FOOTBALL_KEY=your_api_football_key_here
SPORTMONKS_API_TOKEN=your_sportmonks_token_here
FWP_API_KEY=your_football_web_pages_key_here

# ── Scraping ─────────────────────────────────────────────
SCRAPE_DELAY_SECONDS=2

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Notifications (optional) ────────────────────────────
# Slack: pipeline completion + health alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Email: pipeline completion + health alerts
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password-here
# SMTP_FROM=pipeline@footballfam.com
# PIPELINE_MAIL_TO=team@footballfam.com
